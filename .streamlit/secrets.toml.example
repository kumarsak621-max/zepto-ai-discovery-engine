# Streamlit Community Cloud → App settings → Secrets
# Copy these keys into the Cloud Secrets UI (do not commit real values).

# Single key (backward compatible) and/or numbered keys for automatic failover
GEMINI_API_KEY = "YOUR_API_KEY"
GEMINI_API_KEY_1 = ""
GEMINI_API_KEY_2 = ""
GEMINI_API_KEY_3 = ""
GEMINI_API_KEY_4 = ""
GEMINI_API_KEY_5 = ""
GEMINI_API_KEY_6 = ""
GEMINI_API_KEY_7 = ""
GEMINI_API_KEY_8 = ""
GEMINI_API_KEY_9 = ""
GEMINI_API_KEY_10 = ""

GEMINI_MODEL = "gemini-flash-latest"

# Optional failover tuning
# GEMINI_MAX_ATTEMPTS = "6"
# GEMINI_TIMEOUT_SEC = "45"
# GEMINI_BACKOFF_BASE_SEC = "1"
# GEMINI_BACKOFF_MAX_SEC = "16"

PLAYSTORE_APP_ID = "com.zeptoconsumerapp"
PLAYSTORE_REVIEW_COUNT = "500"
PLAYSTORE_CACHE_TTL_HOURS = "6"

APPSTORE_APP_ID = "1575323645"
APPSTORE_COUNTRY = "in"
APPSTORE_REVIEW_COUNT = "200"
APPSTORE_ENABLED = "1"

LIVE_CACHE_TTL_HOURS = "6"
