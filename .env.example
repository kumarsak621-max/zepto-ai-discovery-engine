# Zepto AI Discovery Engine — local secrets (do NOT commit real values)

# Gemini — single key (backward compatible) OR multiple keys for failover
GEMINI_API_KEY=YOUR_API_KEY
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=

GEMINI_MODEL=gemini-flash-latest

# Optional Gemini failover tuning
# GEMINI_MAX_ATTEMPTS=6
# GEMINI_TIMEOUT_SEC=45
# GEMINI_BACKOFF_BASE_SEC=1
# GEMINI_BACKOFF_MAX_SEC=16
# GEMINI_CIRCUIT_COOLDOWN_SEC=120

# Google Play
PLAYSTORE_APP_ID=com.zeptoconsumerapp
PLAYSTORE_REVIEW_COUNT=500
PLAYSTORE_CACHE_TTL_HOURS=6

# Apple App Store (iTunes RSS — no API key). Set APPSTORE_ENABLED=0 to disable.
APPSTORE_APP_ID=1575323645
APPSTORE_COUNTRY=in
APPSTORE_REVIEW_COUNT=200
APPSTORE_ENABLED=1

LIVE_CACHE_TTL_HOURS=6
# Reviews with review_date within this many days count as "Live"
LIVE_REVIEW_WINDOW_DAYS=7
# Auto-check for new store reviews every N minutes while the app is open
AUTO_REFRESH_MINUTES=30
DAILY_SCHEDULE_HOUR=6
