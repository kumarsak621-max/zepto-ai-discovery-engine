# Zepto AI Discovery Engine — local secrets (do NOT commit real values)
# Copy to .env and fill in. On Streamlit Community Cloud, use App settings → Secrets.

# Gemini AI (required for rich analysis; app still starts without it)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Reddit API (optional — https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=zepto_ai_engine/1.0 by ZeptoPMResearch

# Twitter/X API (optional placeholder)
TWITTER_BEARER_TOKEN=

# Pipeline settings
PLAYSTORE_APP_ID=com.zeptoconsumerapp
PLAYSTORE_REVIEW_COUNT=500
PLAYSTORE_CACHE_TTL_HOURS=6
REDDIT_POST_LIMIT=50
DAILY_SCHEDULE_HOUR=6

# Optional override (relative to project root). Default: database/feedback.db
# DATABASE_PATH=database/feedback.db
