# Gemini AI (required for rich analysis; app still starts without it)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Reddit API (optional — https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=zepto_ai_engine/1.0 by ZeptoPMResearch

# Twitter/X API (optional placeholder)
TWITTER_BEARER_TOKEN=

# Pipeline settings
PLAYSTORE_APP_ID=com.zeptoconsumerapp
PLAYSTORE_REVIEW_COUNT=100
REDDIT_POST_LIMIT=50
DAILY_SCHEDULE_HOUR=6

# Server (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8000
